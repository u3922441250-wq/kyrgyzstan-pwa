  <Folder><name>📋 Zone Permesso Militare</name>
    <Placemark><name>⚠️ Sary-Jaz Valley — PERMESSO</name><description>Zona militare confine Cina. Richiedere permesso in anticipo.</description><styleUrl>#permit</styleUrl><Point><coordinates>79.5000,42.5000</coordinates></Point></Placemark>
