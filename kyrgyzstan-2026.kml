<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Kyrgyzstan Road Trip 2026</name>
  <description>30 maggio - 12 giugno 2026 — Leo &amp; Edu</description>

  <Style id="day"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon></IconStyle></Style>
  <Style id="poi"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-circle.png</href></Icon></IconStyle></Style>
  <Style id="fuel"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon></IconStyle></Style>
  <Style id="permit"><IconStyle><Icon><href>http://maps.google.com/mapfiles/kml/paddle/purple-circle.png</href></Icon></IconStyle></Style>

  <!-- DAY 1 — Bishkek -->
  <Folder><name>G1 — Bishkek (30 mag)</name>
    <Placemark><name>Aeroporto Manas</name><description>SIM O!, cambio soldi</description><styleUrl>#day</styleUrl><Point><coordinates>74.4776,43.0553</coordinates></Point></Placemark>
    <Placemark><name>Osh Bazaar Bishkek</name><description>Tanica, compressore, corda traino</description><styleUrl>#poi</styleUrl><Point><coordinates>74.5900,42.8700</coordinates></Point></Placemark>
    <Placemark><name>Piazza Ala-Too</name><description>Centro Bishkek</description><styleUrl>#poi</styleUrl><Point><coordinates>74.5698,42.8746</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 2 — Bishkek → Karakol -->
  <Folder><name>G2 — Bishkek → Karakol (31 mag)</name>
    <Placemark><name>Ala-Archa NP</name><description>Hike Ak-Sai Waterfall</description><styleUrl>#poi</styleUrl><Point><coordinates>74.4847,42.6464</coordinates></Point></Placemark>
    <Placemark><name>Konorchek Canyon</name><description>Red canyon, hike 1-2h</description><styleUrl>#poi</styleUrl><Point><coordinates>75.8500,42.6833</coordinates></Point></Placemark>
    <Placemark><name>Mars Canyon</name><description>Paesaggio marziano</description><styleUrl>#poi</styleUrl><Point><coordinates>75.8200,42.6700</coordinates></Point></Placemark>
    <Placemark><name>Burana Tower</name><description>Minareto XI sec, Via della Seta</description><styleUrl>#poi</styleUrl><Point><coordinates>75.2503,42.7472</coordinates></Point></Placemark>
    <Placemark><name>Karakol</name><description>Arrivo sera</description><styleUrl>#day</styleUrl><Point><coordinates>78.3936,42.4907</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 3 — Jyrgalan -->
  <Folder><name>G3 — Jyrgalan Valley (1 giu)</name>
    <Placemark><name>Jyrgalan</name><description>Waterfall Trail / Kok-Bel Pass</description><styleUrl>#poi</styleUrl><Point><coordinates>79.2094,42.8186</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 4 — Altyn-Arashan -->
  <Folder><name>G4 — Altyn-Arashan (2 giu)</name>
    <Placemark><name>Trailhead Altyn-Arashan</name><description>Hike 3-4h, +800m</description><styleUrl>#poi</styleUrl><Point><coordinates>78.5261,42.6592</coordinates></Point></Placemark>
    <Placemark><name>Hot Springs 2600m</name><description>Sorgenti termali segrete</description><styleUrl>#poi</styleUrl><Point><coordinates>78.5700,42.7500</coordinates></Point></Placemark>
    <Placemark><name>Red Hills</name><description>Colline rosse</description><styleUrl>#poi</styleUrl><Point><coordinates>78.5000,42.0000</coordinates></Point></Placemark>
    <Placemark><name>Kol-Ukok</name><description>Lago alpino, horse riding</description><styleUrl>#poi</styleUrl><Point><coordinates>78.3000,42.0500</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 5 — Sary-Jaz -->
  <Folder><name>G5 — Sary-Jaz Valley (3 giu) ⚠️PERMESSO</name>
    <Placemark><name>Sary-Jaz Valley</name><description>PERMESSO CONFINE! Zona remota</description><styleUrl>#permit</styleUrl><Point><coordinates>79.5000,42.5000</coordinates></Point></Placemark>
    <Placemark><name>Inylchek area</name><description>Campeggio stelle</description><styleUrl>#poi</styleUrl><Point><coordinates>79.8000,42.2500</coordinates></Point></Placemark>
    <Placemark><name>Kara-Tash</name><description>"Islanda del Kirghizistan"</description><styleUrl>#poi</styleUrl><Point><coordinates>78.8000,42.1500</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 6 — South Issyk-Kul -->
  <Folder><name>G6 — Sponda Sud Issyk-Kul (4 giu)</name>
    <Placemark><name>Ak-Say Canyon</name><description>Golden hour sul lago!</description><styleUrl>#poi</styleUrl><Point><coordinates>76.8000,42.3500</coordinates></Point></Placemark>
    <Placemark><name>Seven Bulls Rock</name><description>Formazioni rocciose</description><styleUrl>#poi</styleUrl><Point><coordinates>77.5500,42.2800</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 7 — Barskoon + Skazka -->
  <Folder><name>G7 — Barskoon + Skazka (5 giu)</name>
    <Placemark><name>Barskoon Waterfall</name><description>Cascata + gorge</description><styleUrl>#poi</styleUrl><Point><coordinates>77.6000,42.1500</coordinates></Point></Placemark>
