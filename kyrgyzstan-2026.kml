  <!-- DAY 14 — Arslanbob → Osh → Bishkek -->
  <Folder><name>G14 — Arslanbob → Osh → Bishkek (12 giu)</name>
    <Placemark><name>Sulaiman-Too Osh</name><description>Montagna sacra UNESCO</description><styleUrl>#poi</styleUrl><Point><coordinates>72.7964,40.5278</coordinates></Point></Placemark>
