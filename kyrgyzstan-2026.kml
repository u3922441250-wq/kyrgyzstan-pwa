  </Folder>

  <!-- DAY 13 — Kazarman → Arslanbob -->
  <Folder><name>G13 — Kazarman → Arslanbob (11 giu)</name>
    <Placemark><name>Kazarman</name><description>Tappa intermedia</description><styleUrl>#poi</styleUrl><Point><coordinates>74.0333,41.4000</coordinates></Point></Placemark>
    <Placemark><name>Arslanbob</name><description>Foresta noci, homestay</description><styleUrl>#day</styleUrl><Point><coordinates>72.9389,41.3311</coordinates></Point></Placemark>
