  </Folder>

  <!-- DAY 8 — Bokonbayevo -->
  <Folder><name>G8 — Eagle Hunting (6 giu)</name>
    <Placemark><name>CBT Bokonbayevo</name><description>Eagle hunting demo</description><styleUrl>#day</styleUrl><Point><coordinates>76.9900,42.1208</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 9 — Song-Kul -->
  <Folder><name>G9 — Song-Kul (7 giu)</name>
    <Placemark><name>CBT Kochkor</name><description>ULTIMO CARBURANTE! Feltro</description><styleUrl>#fuel</styleUrl><Point><coordinates>75.7592,42.0133</coordinates></Point></Placemark>
    <Placemark><name>Song-Kul Lake</name><description>3016m, yurta camp</description><styleUrl>#day</styleUrl><Point><coordinates>75.1500,41.8333</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 10 — Song-Kul full -->
  <Folder><name>G10 — Song-Kul Completa (8 giu)</name>
    <Placemark><name>Song-Kul</name><description>Cavalli, kumys, drone, stargazing</description><styleUrl>#day</styleUrl><Point><coordinates>75.1500,41.8333</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 11 — Tash Rabat -->
  <Folder><name>G11 — Naryn → Tash Rabat (9 giu)</name>
    <Placemark><name>Naryn</name><description>ULTIMO ATM! Benzina</description><styleUrl>#fuel</styleUrl><Point><coordinates>76.0014,41.4287</coordinates></Point></Placemark>
    <Placemark><name>Kok-Kiya Canyon</name><description>Off the beaten track</description><styleUrl>#poi</styleUrl><Point><coordinates>75.5000,41.0000</coordinates></Point></Placemark>
    <Placemark><name>Tash Rabat</name><description>Caravanserraglio XV sec, 3200m</description><styleUrl>#day</styleUrl><Point><coordinates>75.2847,40.8453</coordinates></Point></Placemark>
  </Folder>

  <!-- DAY 12 — Kel-Suu -->
  <Folder><name>G12 — Kel-Suu (10 giu) ⚠️PERMESSO</name>
    <Placemark><name>At-Bashy</name><description>Noleggio UAZ</description><styleUrl>#poi</styleUrl><Point><coordinates>75.7986,41.1714</coordinates></Point></Placemark>
